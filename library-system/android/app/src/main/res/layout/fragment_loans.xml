<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/dark_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_loans_header"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="16dp"
            android:layout_marginTop="@dimen/header_top_padding"
            android:layout_marginBottom="12dp"/>

        <!-- Action buttons - the pill row for this screen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnConfirmLoan"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="@string/btn_confirm_loan" android:textSize="@dimen/text_body"
                style="@style/Widget.HomeLibrary.Button.Outline" android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_scan" app:iconTint="@color/dark_text" app:iconGravity="textStart"/>

            <Button
                android:id="@+id/btnScanToReturn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="@string/btn_scan_to_return" android:textSize="@dimen/text_body"
                style="@style/Widget.HomeLibrary.Button.Outline"
                app:icon="@drawable/ic_scan" app:iconTint="@color/dark_text" app:iconGravity="textStart" />

        </LinearLayout>

        <!-- Outer content card - touches bottom of screen -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_top_rounded">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerLoans"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:paddingBottom="@dimen/content_bottom_padding_extra"
                    android:clipToPadding="false"/>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Active Loans / Overdue List toggle - floats above the card, just above the nav bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="@dimen/floating_element_bottom_margin">

        <Button
            android:id="@+id/tabActive"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
            android:text="@string/tab_active_loans" android:textSize="@dimen/text_body"
            style="@style/Widget.HomeLibrary.Button.Black.Small" android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/tabOverdue"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
            android:text="@string/tab_overdue_list" android:textSize="@dimen/text_body"
            style="@style/Widget.HomeLibrary.Button.White.Small"
            android:backgroundTint="@color/white"
            android:textColor="@color/dark_text"/>

    </LinearLayout>

</FrameLayout>
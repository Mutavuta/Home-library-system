<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/dark_green"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Borrower name + status badge row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView android:id="@+id/tvBorrowerName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/white"/>

            <!-- Background color and text set in LoansFragment based on status -->
            <TextView android:id="@+id/tvStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/white"
                android:background="@drawable/bg_status_badge"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- Book title -->
        <TextView android:id="@+id/tvBookTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="@color/white"
            android:layout_marginBottom="2dp"/>

        <!-- Borrower email -->
        <TextView android:id="@+id/tvBorrowerEmail"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/hint_white"
            android:layout_marginBottom="2dp"/>

        <!-- Due date - color changes to overdue_red if overdue, set in LoansFragment -->
        <TextView android:id="@+id/tvDueDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/hint_white"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/dark_green"
    app:cardElevation="0dp"
    android:layout_marginLeft="8dp"
    android:layout_marginRight="8dp"
    android:layout_marginTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Borrower name + date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView android:id="@+id/tvBorrowerName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView android:id="@+id/tvDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/hint_white"/>
        </LinearLayout>

        <!-- Book title -->
        <TextView android:id="@+id/tvTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="@color/white"
            android:layout_marginBottom="2dp"/>

        <!-- Copy assigned or "No Copy Assigned" -->
        <TextView android:id="@+id/tvAssigned"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/hint_white"
            android:layout_marginBottom="12dp"/>

        <!-- Action buttons - visibility toggled in HoldsFragment based on status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnApprove"
                android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1"
                android:text="@string/btn_approve" android:textSize="13sp"
                style="@style/Widget.HomeLibrary.Button.Outline.Small"
                android:backgroundTint="@color/white"
                android:textColor="@color/dark_text"
                android:layout_marginEnd="8dp"/>

            <Button android:id="@+id/btnExpire"
                android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1"
                android:text="@string/btn_expire" android:textSize="13sp"
                style="@style/Widget.HomeLibrary.Button.Black.Small"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Standard spacing used throughout the app -->
    <dimen name="spacing_small">8dp</dimen>
    <dimen name="spacing_medium">16dp</dimen>
    <dimen name="spacing_large">24dp</dimen>

    <!-- Card corner radius -->
    <dimen name="card_corner_radius">12dp</dimen>

    <!-- Bottom navigation height -->
    <dimen name="bottom_nav_height">64dp</dimen>

    <!-- Stat card minimum height on dashboard -->
    <dimen name="stat_card_height">100dp</dimen>

    <!-- Text sizes -->
    <dimen name="text_small">12sp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_medium">16sp</dimen>
    <dimen name="text_large">20sp</dimen>
    <dimen name="text_title">24sp</dimen>
    <dimen name="stat_number">36sp</dimen>

    <!-- Bottom nav floating margins -->
    <dimen name="nav_side_margin">16dp</dimen>
    <dimen name="nav_bottom_margin">22dp</dimen>

    <!-- Bottom padding for scrollable content so the floating nav never covers the last item -->
    <dimen name="content_bottom_padding">80dp</dimen>
    <!-- Extra padding for screens that also have a floating button/toggle row above the nav -->
    <dimen name="content_bottom_padding_extra">150dp</dimen>
    <!-- How far above the nav a floating button/toggle row sits -->
    <dimen name="floating_element_bottom_margin">88dp</dimen>
    <!-- Space above screen header -->
    <dimen name="header_top_padding">44dp</dimen>
</resources>